# Ethereum mainnet JSON-RPC endpoint used to read the CryptoPunks contract.
# Server-side only — never exposed to the browser. Reads are proxied through
# the /api/rpc route so an API key in this URL stays private.
RPC_URL=

# WalletConnect / Reown project id, used by RainbowKit to power the wallet
# connect modal. Get one at https://cloud.reown.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
